{
    "format_version": "1.10.0",
    "minecraft:client_entity": {
        "description": {
            "identifier": "minecraft:player",
            "materials": {
                "default": "entity_alphatest",
                "cape":    "entity_alphatest"
            },
            "textures": {
                "default": "textures/entity/steve",
                "cape":    "textures/entity/cape_invisible",
                "bat":     "textures/entity/vampire_bat"
            },
            "geometry": {
                "default": "geometry.humanoid.custom",
                "bat":     "geometry.bat"
            },
            "scripts": {
                "pre_animation": [
                    "variable.is_bat = query.has_tag('bat_form');"
                ],
                "animate": [
                    { "root": "!variable.is_bat" },
                    { "wing_flap": "variable.is_bat" },
                    { "bat_idle":  "variable.is_bat" }
                ]
            },
            "animations": {
                "root":      "controller.animation.vampire_bat.transform",
                "wing_flap": "animation.vampire_bat.wing_flap",
                "bat_idle":  "animation.vampire_bat.idle",
                "move":                     "animation.player.move",
                "look_at_target_default":   "animation.player.look_at_target.default",
                "look_at_target_gliding":   "animation.player.look_at_target.gliding",
                "look_at_target_swimming":  "animation.player.look_at_target.swimming",
                "look_at_target_inverted":  "animation.player.look_at_target.inverted",
                "cape":                     "animation.player.cape",
                "holding":                  "animation.player.holding",
                "brandish_spear":           "animation.player.brandish_spear",
                "charging":                 "animation.player.charging",
                "attack.rotations":         "animation.player.attack.rotations",
                "sneaking":                 "animation.player.sneaking",
                "bob":                      "animation.player.bob",
                "damage_nearby_mobs":       "animation.player.damage_nearby_mobs",
                "fishing_rod":              "animation.player.fishing_rod",
                "use_item_progress":        "animation.player.use_item_progress",
                "swimming":                 "animation.player.swim",
                "swim.arms":                "animation.player.swim.arms",
                "riding.arms":              "animation.player.riding.arms",
                "riding.legs":              "animation.player.riding.legs",
                "holding_spyglass":         "animation.player.holding_spyglass",
                "crawling":                 "animation.player.crawling",
                "digging":                  "animation.player.digging",
                "crossbow_hold":            "animation.player.crossbow_hold",
                "crossbow_charge":          "animation.player.crossbow_charge",
                "shield_block_main_hand":   "animation.player.shield_block_main_hand",
                "shield_block_off_hand":    "animation.player.shield_block_off_hand"
            },
            "render_controllers": [
                "controller.render.vampire_bat_player"
            ],
            "enable_attachables": true
        }
    }
}
