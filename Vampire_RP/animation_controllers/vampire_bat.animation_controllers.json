{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.vampire_bat.transform": {
            "initial_state": "human",
            "states": {
                "human": {
                    "transitions": [
                        { "bat": "query.has_tag('bat_form')" }
                    ]
                },
                "bat": {
                    "animations": [
                        "wing_flap",
                        "idle"
                    ],
                    "transitions": [
                        { "human": "!query.has_tag('bat_form')" }
                    ]
                }
            }
        }
    }
}
